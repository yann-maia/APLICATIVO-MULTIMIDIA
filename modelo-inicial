// variável global de controle de tela

int screen = 0;

// criação dos objetos "intro", etc. pertencentes a classe "Screen"

Screen intro;
Screen summary;
Screen credits;
Screen teory;
Screen questions;
Screen answers;
Screen flashcards;

// criação dos objetos "bx" pertencentes a classe "Buttons"

Buttons exitButton;
Buttons backButton;

Buttons b1;
Buttons b2;
Buttons b3;

Buttons b4;
Buttons b5;
Buttons b6;

Buttons b7;
Buttons b8;
Buttons b9;

// controle de cores

color mainScreenCol = color(0,50,255);
color secondScreenCol = color(0,20,200);
color thirdScreenCol = color(0,30,150);
color mainButtonCol = color(30,200,200);
color secondaryButtonCol = color(250,250,250);
color exitButtonCol = color(200,0,0);
color backButtonCol = color(0,0,240);

void setup(){

  // definição de tela em fullscreen (modo JAVA2D)

  fullScreen(JAVA2D);

  // atribuição de parâmetros da tela (Screen)

  intro   = new Screen(mainScreenCol, secondScreenCol, 1);
  summary = new Screen(mainScreenCol, secondScreenCol, 2);
  credits = new Screen(mainScreenCol, secondScreenCol, 1);
  teory = new Screen(mainScreenCol, secondScreenCol, 3);
  questions = new Screen(mainScreenCol, secondScreenCol, 3);
  answers = new Screen(mainScreenCol, secondScreenCol, 3);
  flashcards = new Screen(mainScreenCol, secondScreenCol, 3);

  // atribuição de parâmetros dos botões (Buttons)
  
  exitButton = new Buttons(0.92, 0.03, 0.06, 0.06, exitButtonCol);
  backButton = new Buttons(0.92, 0.03, 0.06, 0.06, backButtonCol);
  
  b1 = new Buttons(0.2, 0.2, 0.12, 0.1, mainButtonCol);
  b2 = new Buttons(0.44, 0.2, 0.12, 0.1, mainButtonCol);
  b3 = new Buttons(0.68, 0.2, 0.12, 0.1, mainButtonCol);
  b4 = new Buttons(0.2, 0.35, 0.12, 0.1, mainButtonCol);
  b5 = new Buttons(0.44, 0.35, 0.12, 0.1, mainButtonCol);
  b6 = new Buttons(0.68, 0.35, 0.12, 0.1, mainButtonCol);
}

void draw(){

  // condicional de tela, "monta" o layout

  if (screen == 0) {
    b1.hover();
    b2.hover();
    b3.hover();
    b4.hover();
    b5.hover();
    b6.hover();
    exitButton.hover();

    intro.drawScreen();
    b1.drawButton();
    b1.drawText("Sumário");
    b2.drawButton();
    b2.drawText("Teoria");
    b3.drawButton();
    b3.drawText("Créditos");
    b4.drawButton();
    b4.drawText("Questões");
    b5.drawButton();
    b5.drawText("Revisão");
    exitButton.drawButton();
    exitButton.drawText("Sair");
  }
  
  if (screen == 1) {
    backButton.hover();
  
    summary.drawScreen();
    backButton.drawButton();
    backButton.drawText("Voltar");
  }
  
  if (screen == 2) {
    backButton.hover();
  
    teory.drawScreen();
    backButton.drawButton();
    backButton.drawText("Voltar");
  }
  
  if (screen == 3) {
    backButton.hover();
  
    questions.drawScreen();
    backButton.drawButton();
    backButton.drawText("Voltar");
  }
  
  if (screen == 4) {
    backButton.hover();
  
    answers.drawScreen();
    backButton.drawButton();
    backButton.drawText("Voltar");
  }
  
  if (screen == 5) {
    backButton.hover();
  
    flashcards.drawScreen();
    backButton.drawButton();
    backButton.drawText("Voltar");
  }
  
  if (screen == 6) {
    exitButton.hover();
  
    credits.drawScreen();
    backButton.drawButton();
    backButton.drawText("Voltar");
  }
}

// bloqueia a tecla "ESC", fecha a janela somente com o botão

void keyPressed(){

  if (key == ESC){
    key = 0;
  }
}

// função de detecção de clique

void mousePressed(){
  
  if (b1.isMouseOver() && screen == 0){
    screen = 1;
  }
  
  if (b2.isMouseOver() && screen == 0){
    screen = 2;
  }
  
  if (b3.isMouseOver() && screen == 0){
    screen = 6;
  }
  
  if (b4.isMouseOver() && screen == 0){
    screen = 3;
  }
  
  if (b5.isMouseOver() && screen == 0){
    screen = 5;
  }
  
  if (exitButton.isMouseOver() && screen == 0){
    exit();
  }
  
  if (backButton.isMouseOver() && screen != 0){
    screen = 0;
  }
}

// classe para os botões

class Buttons {

  float relX, relY;
  float relW, relH;

  color buttonCol;
  color baseCol;

  Buttons(float relX, float relY, float relW, float relH, color buttonCol){

    this.relX = relX;
    this.relY = relY;
    this.relW = relW;
    this.relH = relH;

    this.buttonCol = buttonCol;
    this.baseCol = buttonCol;
  }

  // método "drawButton", desenha os botões

  void drawButton(){

    float x = relX * width;
    float y = relY * height;
    float w = relW * width;
    float h = relH * height;

    noStroke();
    fill(buttonCol);
    rect(x, y, w, h);
  }

  // método "drawText", desenha texto

  void drawText(String txt){

    float x = relX * width;
    float y = relY * height;
    float w = relW * width;
    float h = relH * height;

    fill(255);
    textAlign(CENTER, CENTER);
    textSize(h * 0.5);

    text(txt, x + w/2, y + h/2);
  }

  // método "hover", muda cor com o "passar por cima" do cursor

  void hover(){

    if (isMouseOver()){

      buttonCol = color(
        min(red(baseCol) + 30, 255), 
        min(green(baseCol) + 30, 255), 
        min(blue(baseCol) + 30, 255)
      );

    } else {
      buttonCol = baseCol;
    }    
  }

  // retorna true com base na posição do mouse "em cima" do botão

  boolean isMouseOver(){

    float x = relX * width;
    float y = relY * height;
    float w = relW * width;
    float h = relH * height;

    return (mouseX > x && mouseX < x + w && mouseY > y && mouseY < y + h);    
  }
}

// classe para as telas

class Screen {

  color mainScreenCol;
  color secondScreenCol;
  int type;

  Screen(color mainScreenCol, color secondScreenCol, int type){

    this.mainScreenCol = mainScreenCol;
    this.secondScreenCol = secondScreenCol;
    this.type = type;
  }

  // método "drawScreen", desenha a tela

  void drawScreen(){

    noStroke();
    fill(mainScreenCol);
    rect(0,0,width,height);   
    
    if (this.type == 1){
      noStroke();
      fill(secondScreenCol);
      rect(0,0,width,height*0.12); 
    }
    
    if (this.type == 2){
      noStroke();
      fill(thirdScreenCol);
      rect(0,0,width*0.1,height); 
      rect(width*0.9,0,width,height);
      fill(secondScreenCol);
      rect(0,0,width,height*0.12);
    }
    
    if (this.type == 3){
      noStroke();
      fill(thirdScreenCol);
      rect(0,0,width*0.1,height);
      fill(secondScreenCol);
      rect(0,0,width,height*0.12);
    } 
  }
}
